using System;
using System.Collections.Generic;
using System.Linq;

namespace KalkulatorDelegaty
{
    class Program
    {
        // Delegat dla działań matematycznych
        delegate double Operacja(double a, double b);

        // Historia obliczeń
        static List<string> historia = new List<string>();

        // Lista wyników do statystyk
        static List<double> wyniki = new List<double>();

        static void Main(string[] args)
        {
            bool dziala = true;

            while (dziala)
            {
                Console.Clear();
                Console.WriteLine("=== KALKULATOR ===");
                Console.WriteLine("1. Dodawanie");
                Console.WriteLine("2. Odejmowanie");
                Console.WriteLine("3. Mnożenie");
                Console.WriteLine("4. Dzielenie");
                Console.WriteLine("5. Pokaż historię");
                Console.WriteLine("6. Wyczyść historię");
                Console.WriteLine("7. Pokaż statystyki");
                Console.WriteLine("0. Zakończ");
                Console.Write("Wybierz opcję: ");

                string wybor = Console.ReadLine();

                switch (wybor)
                {
                    case "1":
                        WykonajDzialanie("+", Dodawanie);
                        break;

                    case "2":
                        WykonajDzialanie("-", Odejmowanie);
                        break;

                    case "3":
                        WykonajDzialanie("*", Mnozenie);
                        break;

                    case "4":
                        WykonajDzialanie("/", Dzielenie);
                        break;

                    case "5":
                        PokazHistorie();
                        break;

                    case "6":
                        WyczyscHistorie();
                        break;

                    case "7":
                        PokazStatystyki();
                        break;

                    case "0":
                        dziala = false;
                        break;

                    default:
                        Console.WriteLine("Nieprawidłowa opcja!");
                        Pauza();
                        break;
                }
            }
        }

        // Metody matematyczne
        static double Dodawanie(double a, double b)
        {
            return a + b;
        }

        static double Odejmowanie(double a, double b)
        {
            return a - b;
        }

        static double Mnozenie(double a, double b)
        {
            return a * b;
        }

        static double Dzielenie(double a, double b)
        {
            if (b == 0)
            {
                throw new DivideByZeroException("Nie można dzielić przez zero!");
            }

            return a / b;
        }

        // Wykonanie działania za pomocą delegata
        static void WykonajDzialanie(string znak, Operacja operacja)
        {
            try
            {
                Console.Write("Podaj pierwszą liczbę: ");
                double a = Convert.ToDouble(Console.ReadLine());

                Console.Write("Podaj drugą liczbę: ");
                double b = Convert.ToDouble(Console.ReadLine());

                double wynik = operacja(a, b);

                string zapis = $"{a} {znak} {b} = {wynik}";

                historia.Add(zapis);
                wyniki.Add(wynik);

                Console.WriteLine("Wynik: " + wynik);
            }
            catch (DivideByZeroException ex)
            {
                Console.WriteLine("Błąd: " + ex.Message);
            }
            catch (FormatException)
            {
                Console.WriteLine("Błąd: Wprowadzono nieprawidłowe dane!");
            }

            Pauza();
        }

        // Wyświetlanie historii
        static void PokazHistorie()
        {
            Console.WriteLine("\n=== HISTORIA OBLICZEŃ ===");

            if (historia.Count == 0)
            {
                Console.WriteLine("Brak zapisanych obliczeń.");
            }
            else
            {
                foreach (string wpis in historia)
                {
                    Console.WriteLine(wpis);
                }
            }

            Pauza();
        }

        // Czyszczenie historii
        static void WyczyscHistorie()
        {
            historia.Clear();
            wyniki.Clear();

            Console.WriteLine("Historia została wyczyszczona.");
            Pauza();
        }

        // Statystyki wyników
        static void PokazStatystyki()
        {
            Console.WriteLine("\n=== STATYSTYKI ===");

            if (wyniki.Count == 0)
            {
                Console.WriteLine("Brak danych do obliczenia statystyk.");
            }
            else
            {
                Console.WriteLine($"Suma wyników: {wyniki.Sum()}");
                Console.WriteLine($"Średnia wyników: {wyniki.Average()}");
                Console.WriteLine($"Najmniejszy wynik: {wyniki.Min()}");
                Console.WriteLine($"Największy wynik: {wyniki.Max()}");
            }

            Pauza();
        }

        // Pauza programu
        static void Pauza()
        {
            Console.WriteLine("\nNaciśnij dowolny klawisz, aby kontynuować...");
            Console.ReadKey();
        }
    }
}
